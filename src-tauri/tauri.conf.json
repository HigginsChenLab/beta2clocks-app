{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "beta2clocks",
  "version": "0.1.3",
  "identifier": "io.translage.beta2clocks",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "beta2clocks",
        "width": 1000,
        "height": 780,
        "minWidth": 840,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/preflight.R"],
    "category": "DeveloperTool",
    "shortDescription": "Calculate epigenetic clocks from DNA methylation data.",
    "longDescription": "beta2clocks computes 20+ epigenetic clocks (Horvath, Hannum, PhenoAge, GrimAge, DunedinPACE, SystemsAge and more) from a DNA methylation .RData file, using the TranslAGE methylCIPHER pipeline running inside the public beta2clocks Docker image."
  },
  "plugins": {}
}
